{
  "permissions": {
    "allow": [
      "Bash(mise run test *)",
      "Bash(mise run format *)",
      "Bash(mise run format:check *)",
      "Bash(mise run oas *)",
      "Bash(mise run docs *)",
      "Bash(mise run test:build *)",
      "Bash(mise run test:shell *)",
      "Bash(mise run test:down *)",
      "Bash(docker compose *)",
      "Bash(uv run ruff *)",
      "Bash(uv run pytest *)",
      "mcp__linear-virtool__get_*",
      "mcp__linear-virtool__list_*",
      "mcp__linear-virtool__search_*",
      "mcp__linear-virtool__extract_*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(*.py)|Edit(*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff format $(jq -r '.tool_input.file_path')",
            "timeout": 30,
            "statusMessage": "Formatting with ruff..."
          }
        ]
      }
    ]
  }
}
